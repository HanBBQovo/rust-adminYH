{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "宇涵物流订单系统",
  "version": "0.1.0",
  "identifier": "com.yuhang.admin",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5278",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "宇涵物流订单系统",
        "width": 1360,
        "height": 860,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset:; connect-src 'self' http://127.0.0.1:16824 https:; img-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
